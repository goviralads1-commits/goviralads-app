# Admin Panel Environment Configuration
# Copy this to .env and set values

# Development
VITE_API_URL=http://localhost:3000

# Production (set this in Vercel Dashboard)
# VITE_API_URL=https://api.goviralads.com

VITE_APP_NAME=TaskFlow Admin
VITE_APP_VERSION=1.0.0

# =================================
# FIREBASE (Push Notifications)
# =================================
# Go to https://console.firebase.google.com
# 1. Create project → Project settings → Web app → Get config
# 2. Cloud Messaging → Generate VAPID key pair
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_VAPID_KEY=your_vapid_key
