# =============================================
# GOVIRALADS - ENVIRONMENT CONFIGURATION
# =============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# FREE HOSTING STACK:
# - Frontend: Vercel (free)
# - Backend: Railway or Render (free tier)
# - Database: MongoDB Atlas (free 512MB)
# - Email: Gmail/Brevo/Zoho SMTP (free)
# - Domain: goviralads.com

# =================================
# SERVER
# =================================
# Railway/Render will auto-assign PORT
PORT=5000
NODE_ENV=production

# =================================
# DATABASE (MongoDB Atlas - FREE)
# =================================
# 1. Go to mongodb.com/atlas
# 2. Create free M0 cluster
# 3. Create database user
# 4. Whitelist 0.0.0.0/0 for Railway/Render
# 5. Get connection string

# Development
# MONGODB_URI=mongodb://localhost:27017/goviralads

# Production (MongoDB Atlas FREE)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/goviralads?retryWrites=true&w=majority

# =================================
# JWT AUTHENTICATION
# =================================
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d

# =================================
# CORS (allowed origins)
# =================================
# Development
# CORS_ORIGINS=http://localhost:5173,http://localhost:5175

# Production (Update with your Vercel URLs)
# Format: https://your-admin.vercel.app,https://your-client.vercel.app
# Or custom domain: https://admin.goviralads.com,https://app.goviralads.com
CORS_ORIGINS=https://admin.goviralads.com,https://app.goviralads.com

# =================================
# EMAIL CONFIGURATION (Resend API)
# =================================
# Sign up at https://resend.com (free tier: 100 emails/day)
# 1. Create account and verify domain
# 2. Generate API key from dashboard
# 3. Set variables below

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@goviralads.com
EMAIL_FROM_NAME=Go Viral Ads

# --- LEGACY SMTP (deprecated, use Resend instead) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# =================================
# ADMIN NOTIFICATIONS
# =================================
# Admin receives: client ticket replies, overdue alerts, purchase notifications
ADMIN_EMAIL=admin@goviralads.com

# =================================
# APPLICATION URLs
# =================================
ADMIN_URL=https://admin.goviralads.com
CLIENT_URL=https://app.goviralads.com
API_URL=https://api.goviralads.com

# =================================
# REMINDERS (in hours)
# =================================
REMINDER_HOURS_BEFORE=24
OVERDUE_CHECK_INTERVAL=3600000

# =================================
# SECURITY
# =================================
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100

# =================================
# FILE UPLOADS (Cloudinary)
# =================================
# Sign up at https://cloudinary.com (free tier: 25GB storage + 25GB bandwidth/month)
# 1. Create account → Dashboard → copy Cloud Name, API Key, API Secret
# 2. Images are stored in folder: goviralads/chat
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
